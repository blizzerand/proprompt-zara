{
  "name": "@proprompt/zara",
  "version": "1.0.0",
  "private": false,
  "description": "Zara — the ProPrompt website chatbot. Drop-in React component used by both proprompt-website and prompt-store.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blizzerand/proprompt-zara.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "prepare": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch"
  },
  "dependencies": {
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.577.0",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=18"
  }
}
